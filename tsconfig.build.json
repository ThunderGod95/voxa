{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "allowImportingTsExtensions": false,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
    },
    "include": ["src/**/*.ts"],
    "exclude": ["tests/**/*", "dist", "node_modules"],
}
